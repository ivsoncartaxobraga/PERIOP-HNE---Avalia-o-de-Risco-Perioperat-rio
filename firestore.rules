rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: assessments
    // Document ID: assessmentId (string)
    // Fields:
    //   - id: string (required)
    //   - doctorName: string (required)
    //   - doctorCRM: string (required)
    //   - name: string (required)
    //   - dob: string
    //   - age: number
    //   - date: string (required)
    //   - clinicalComplaints: string
    //   - proposedSurgery: string
    //   - functionalCapacity: string
    //   - medications: string
    //   - allergies: string
    //   - riskFactors: list (strings)
    //   - otherRiskFactors: string
    //   - pa: string
    //   - fc: string
    //   - cvExam: map { status: string, details: string }
    //   - respExam: map { status: string, details: string }
    //   - abdExam: map { status: string, details: string }
    //   - extExam: map { status: string, details: string }
    //   - labExams: string
    //   - ecg: string
    //   - echo: string
    //   - cath: string
    //   - otherExams: string
    //   - intrinsicRisk: string
    //   - intrinsicRiskItem: string
    //   - hemorrhagicRisk: string
    //   - hemorrhagicRiskItem: string
    //   - isUrgency: bool
    //   - hasSevereCondition: bool
    //   - severeConditions: list (strings)
    //   - isElective: bool
    //   - electiveRisk: string (optional)
    //   - rcriScore: number
    //   - rcriItems: list (strings)
    //   - aubHas2Score: number
    //   - aubHas2Items: list (strings)
    //   - vsgCriScore: number
    //   - vsgCriItems: list (strings)
    //   - finalRisk: string
    //   - conduct: string
    //   - authorUid: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ivson.braga@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidAssessment(data) {
      return data.id is string &&
             data.doctorName is string && data.doctorName.size() < 100 &&
             data.doctorCRM is string && data.doctorCRM.size() < 20 &&
             data.name is string && data.name.size() < 100 &&
             data.authorUid is string &&
             data.createdAt is timestamp;
    }

    function isValidAutoText(data) {
      return data.id is string &&
             data.text is string && data.text.size() < 5000 &&
             data.authorUid is string &&
             data.createdAt is timestamp;
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidAssessment(request.resource.data) && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && isValidAssessment(request.resource.data) && (isDocOwner() || isAdmin()) && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /autotexts/{autotextId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidAutoText(request.resource.data) && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && isValidAutoText(request.resource.data) && (isDocOwner() || isAdmin()) && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if isAuthenticated();
    }
  }
}
